# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git

# Supabase (get from supabase.com → project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Gemini AI (get from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-latest

# AI Rate Limits
RATE_LIMIT_GUEST=5
RATE_LIMIT_HOURLY=15
RATE_LIMIT_DAILY=100
DAILY_TOTAL_LIMIT=500

# App
NEXT_PUBLIC_SITE_URL=https://agro.com.bd
NEXT_PUBLIC_SITE_NAME=agro.com.bd
